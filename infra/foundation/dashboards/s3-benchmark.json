{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "title": "s3-benchmark - Results (all parallel pods)",
  "uid": "s3-benchmark-results",
  "tags": ["s3sentinel", "benchmark"],
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Data source",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "identity",
        "label": "Identity",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(s3_benchmark_op_success, identity)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Pods reporting",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "count(count by (instance) (s3_benchmark_op_success{identity=~\"$identity\"}))",
          "legendFormat": "pods"
        }
      ]
    },
    {
      "id": 2,
      "title": "Access-denied / failed operations",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "count(s3_benchmark_op_success{identity=~\"$identity\"} == 0) or vector(0)",
          "legendFormat": "failed ops"
        }
      ]
    },
    {
      "id": 3,
      "title": "Operation status (latest push per pod)",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "description": "1 = ok, 0 = failed (e.g. access denied). One row per pod/identity/operation.",
      "fieldConfig": {
        "defaults": { "unit": "none" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "OK" },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "thresholds", "value": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } }
            ]
          }
        ]
      },
      "options": { "showHeader": true },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "instant": true,
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "s3_benchmark_op_success{identity=~\"$identity\"}"
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "job": true } } }
      ]
    },
    {
      "id": 4,
      "title": "Big-file throughput (MB/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "MBs", "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "s3_benchmark_op_throughput_mbps{identity=~\"$identity\"}",
          "legendFormat": "{{identity}} / {{operation}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Small-file / list rate (objects per second)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "ops", "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "s3_benchmark_op_rate_per_second{identity=~\"$identity\"}",
          "legendFormat": "{{identity}} / {{operation}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Wall time per operation (s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 21 },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "s3_benchmark_op_wall_seconds{identity=~\"$identity\"}",
          "legendFormat": "{{identity}} / {{operation}}"
        }
      ]
    }
  ]
}
